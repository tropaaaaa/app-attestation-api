# Main ENV
ENV=local  # local|uat|production
DEBUG_MODE=true
ALLOWED_HOST=*
CONFIG_NAME=Uat/AppAttestationApi/Config
REGION_NAME=ap-southeast-1
PARAMETERS_SECRETS_EXTENSION_LOG_LEVEL=info
PARAMETERS_SECRETS_EXTENSION_HTTP_PORT=2773
ENABLE_STR_LOG_MODE=true
ENABLE_JSON_LOG_MODE=false
X_API_KEY=

# Android - Play Integrity API
ANDROID_PACKAGE_NAME=com.example.myapp
# Service account JSON string (for local dev, paste the full JSON content as a single line)
GOOGLE_SERVICE_ACCOUNT_JSON=

# iOS - App Attestation (future)
IOS_BUNDLE_ID=com.example.myapp
